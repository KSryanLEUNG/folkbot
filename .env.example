# Folkbot secrets — auto-loaded by main.rs via dotenvy::dotenv().
# DO NOT commit this file (already in .gitignore).
# chmod 600 recommended.
# Copy to .env and fill in real values.

# OpenAI-compatible API key (works for OpenAI, Poe, Together, Groq, OpenRouter,
# etc. — pick whichever env var name matches `api_key_env` in folkbot.toml).
OPENAI_API_KEY=

# Telegram bot token (from @BotFather).
# Only one process can long-poll a given token at a time.
TELEGRAM_BOT_TOKEN=
